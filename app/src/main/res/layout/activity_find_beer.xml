<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Spinner
        android:id="@+id/beer_spinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/beer_types"/>
    <Spinner
        android:id="@+id/spinner_zonas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"/>
    <Button
        android:id="@+id/find_beer_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Find Beer"
        android:onClick="onClickFindBeer"/>

    <TextView
        android:id="@+id/brands"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Results will appear here"/>
    <TextView
        android:id="@+id/text_estaciones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estaciones disponibles"
        android:textSize="18sp"
        android:layout_marginTop="20dp"/>

</LinearLayout>